NAME YardSign_Dialogue

DLG 1
"""
{property locked true}{sequence
  - You can't just go back to bed - there's work to do!
  - Seriously? Hit the road already!
  - You're just going to have to get out there are shoot your shot. 
}
"""
NAME FrontDoorLock_Dialogue

DLG 2
{property locked true}You've already locked the gate behind you.
NAME GateLock_Dialogue

